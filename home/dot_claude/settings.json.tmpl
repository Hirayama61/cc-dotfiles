{
  "autoMemoryEnabled": false,
  "env": {
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "false",
    "CLAUDE_CODE_ENABLE_TASKS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "theme": "custom:panda",
  "language": "日本語",
  "effortLevel": "high",
  "statusLine": {
    "type": "command",
    "command": "python3 {{ .chezmoi.homeDir }}/.claude/statusline-command.py"
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": {{ .claude.permissions.allow | toJson }}
  },
  "extraKnownMarketplaces": {
    "dotfiles-lsp": {
      "source": {
        "source": "directory",
        "path": "{{ .chezmoi.homeDir }}/.claude/lsp-marketplace"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "enabledPlugins": {
    "dotfiles-lsp@dotfiles-lsp": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true
  },
  "deniedMcpServers": [
    { "serverUrl": "https://mcp.asana.com/*" },
    { "serverUrl": "https://mcp.box.com/*" },
    { "serverUrl": "https://mcp.canva.com/*" },
    { "serverUrl": "https://gmailmcp.googleapis.com/*" },
    { "serverUrl": "https://mcp.slack.com/*" },
    { "serverUrl": "https://calendarmcp.googleapis.com/*" },
    { "serverUrl": "https://mcp.notion.com/*" },
    { "serverUrl": "https://mcp.monday.com/*" },
    { "serverUrl": "https://mcp.linear.app/*" },
    { "serverUrl": "https://mcp.intercom.com/*" },
    { "serverUrl": "https://mcp.hubspot.com/*" }
  ],
  "skipAutoPermissionPrompt": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "worktree": {
    "baseRef": "head",
    "bgIsolation": "worktree"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-protected-branch-push.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/pre-push-selfreview-gate.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-no-verify.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-nested-worktree.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-gh-mutations.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-force-push.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-amend-pushed.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-destructive-git.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-defer-phrases.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-secret-files.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-test-deletion.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-unreviewed-plan.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-unreviewed-mutation.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/inject-coding-standards.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/pre-edit-guard.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-main-clone-edit.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/block-repo-doc.sh"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/inject-guide-review.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/postcommit-invalidate-review.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/ciwatch-on-pr-create.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/ciwatch-on-push-nudge.sh"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/capture-decision.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/large-file-warn.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/inject-guide-review.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/load-obsidian-memory.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/main-clone-warn.sh"
          }
        ]
      },
      {
        "matcher": "clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/rearm-coding-standards.sh"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/create-worktree.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/selfcheck-on-stop.sh"
          }
        ]
      }
    ]
  }
}
