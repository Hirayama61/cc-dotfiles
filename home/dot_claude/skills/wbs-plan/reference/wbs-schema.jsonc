{
  "案件": "利用者管理リニューアル",
  "要件源": "https://confluence.example.com/PROJ/利用者管理",   // URL でもローカルパスでも可
  "デザイン源": "https://figma.com/file/abc/利用者管理",
  "着手順根拠": "JIRA PROJ-1200 のストーリー順",
  "更新": { "at": "2026-06-30T10:12:00+09:00", "by": "claude" },  // 更新のたびに書き換える

  "画面": [
    {
      "id": "S1", "name": "利用者一覧", "順序": 1,
      "機能": [
        {
          "id": "S1-F1", "name": "検索フィルタ",
          "tasks": [
            { "領域": "FE", "status": "実装中", "pr": null },     // status: 未着手|実装中|PR化済|レビュー中|マージ済
            { "領域": "BE", "status": "PR化済", "pr": "#4821" }   // BE 作業が無ければこの要素を置かない
          ]
        }
      ]
    }
  ],

  "課題": [
    {
      "id": "Q-01",
      "内容": "絞り込み条件をページ遷移後も保持するかが要件に無い",
      "種別": "仕様不明",          // 仕様不明 | デザインミス | 既存実装乖離 | 技術検討
      "確認先": "企画",            // 企画 | デザイナー | BE | 自己解決
      "status": "open",            // open | 確認中 | 解決
      "解決メモ": "",              // 確定した仕様。実装時はこれが正
      "ブロック対象": ["S1-F1.FE"] // タスクキーの配列。確認先が人間系で status が解決でない(open/確認中)とこのタスクは派生でブロック
    }
  ],

  "共通化候補": [
    {
      "id": "C-1",
      "共有ロジック": "一覧の検索フィルタ状態管理",
      "対象機能": ["S1-F1", "S3-F2"],          // 機能ID の配列
      "推奨": "useSearchFilter フックに切り出し",
      "判断": "未"                              // 未 | 採用 | 見送り(人間が決める)
    }
  ]
}
